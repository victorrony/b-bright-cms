{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "B-Bright training courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "organizer": {
      "type": "string",
      "required": true,
      "default": "Geração B-Bright"
    },
    "trainer": {
      "type": "string",
      "required": true
    },
    "credentials": {
      "type": "json"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "extraText": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "details": {
      "type": "json"
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::registration.registration",
      "mappedBy": "course"
    }
  }
}
