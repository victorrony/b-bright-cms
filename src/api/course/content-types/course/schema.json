{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course",
    "description": "B-Bright training courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "organizer": {
      "type": "string",
      "default": "Geração B-Bright",
      "required": true
    },
    "trainer": {
      "type": "string",
      "required": true
    },
    "credentials": {
      "type": "component",
      "component": "shared.credential",
      "repeatable": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "extraText": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "details": {
      "type": "component",
      "component": "shared.detail-item",
      "repeatable": true
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::registration.registration",
      "mappedBy": "course"
    },
    "formFields": {
      "type": "component",
      "component": "shared.form-field",
      "repeatable": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "startDate": {
      "type": "date"
    },
    "duration": {
      "type": "string"
    },
    "spots": {
      "type": "integer"
    },
    "courseStatus": {
      "type": "enumeration",
      "default": "aberto",
      "enum": [
        "aberto",
        "encerrado",
        "em_breve"
      ]
    },
    "price": {
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
