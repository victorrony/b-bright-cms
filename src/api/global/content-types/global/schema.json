{
  "kind": "singleType",
  "collectionName": "global",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Site-wide settings: navbar, footer, contact info"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "default": "B-Bright",
      "required": true
    },
    "siteDescription": {
      "type": "text"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "logoNav": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "navLinks": {
      "type": "component",
      "component": "shared.nav-link",
      "repeatable": true
    },
    "ctaLabel": {
      "type": "string",
      "default": "JOIN US"
    },
    "ctaHref": {
      "type": "string",
      "default": "/#join"
    },
    "footerDescription": {
      "type": "text"
    },
    "footerColumns": {
      "type": "component",
      "component": "shared.footer-column",
      "repeatable": true
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "courseLabelOrganizer": {
      "type": "string"
    },
    "courseLabelTrainer": {
      "type": "string"
    },
    "courseLabelEnroll": {
      "type": "string"
    },
    "copyrightText": {
      "type": "string",
      "default": "All rights reserved."
    },
    "logoFooter": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
