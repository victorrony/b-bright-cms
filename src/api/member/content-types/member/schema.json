{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Member",
    "description": "GBB community member registrations"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "fullName": {
      "type": "string",
      "required": true
    },
    "birthDate": {
      "type": "date",
      "required": true
    },
    "gender": {
      "type": "enumeration",
      "enum": ["masculino", "feminino", "prefiro_nao_dizer"],
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "church": {
      "type": "string"
    },
    "howHeard": {
      "type": "enumeration",
      "enum": ["amigo", "redes_sociais", "evento", "outro"]
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "termsAccepted": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "status": {
      "type": "enumeration",
      "enum": ["pendente", "aprovado", "rejeitado"],
      "default": "pendente"
    }
  }
}
