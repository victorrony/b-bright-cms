{
  "kind": "singleType",
  "collectionName": "homepage",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "All homepage sections content"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "string"
    },
    "heroImage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "heroButtons": {
      "type": "component",
      "component": "shared.hero-button",
      "repeatable": true
    },
    "aboutHeading": {
      "type": "string"
    },
    "aboutBody": {
      "type": "text"
    },
    "aboutMission": {
      "type": "text"
    },
    "aboutVision": {
      "type": "text"
    },
    "missionLabel": {
      "type": "string",
      "default": "OUR MISSION"
    },
    "visionLabel": {
      "type": "string",
      "default": "OUR VISION"
    },
    "aboutPhotos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "values": {
      "type": "component",
      "component": "shared.value-item",
      "repeatable": true
    },
    "timelineTitle": {
      "type": "string"
    },
    "timelineSubtitle": {
      "type": "text"
    },
    "timelineMilestones": {
      "type": "component",
      "component": "shared.milestone",
      "repeatable": true
    },
    "trainingTitle": {
      "type": "string"
    },
    "trainingSubtitle": {
      "type": "text"
    },
    "trainingModules": {
      "type": "component",
      "component": "shared.training-module",
      "repeatable": true
    },
    "stats": {
      "type": "component",
      "component": "shared.stat-item",
      "repeatable": true
    },
    "resultCards": {
      "type": "component",
      "component": "shared.result-card",
      "repeatable": true
    },
    "resultsBackground": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "resultsTitleLine1": {
      "type": "string"
    },
    "resultsTitleLine2": {
      "type": "string"
    },
    "resultsSubtitle": {
      "type": "text"
    },
    "visionTitle": {
      "type": "string"
    },
    "visionSubtitle": {
      "type": "text"
    },
    "visionInitiatives": {
      "type": "component",
      "component": "shared.initiative",
      "repeatable": true
    },
    "coursesLabel": {
      "type": "string",
      "default": "Formação"
    },
    "coursesTitle": {
      "type": "string",
      "default": "Cursos da Geração"
    },
    "coursesLinkLabel": {
      "type": "string",
      "default": "Ver todos os cursos"
    },
    "galleryLabel": {
      "type": "string",
      "default": "Galeria"
    },
    "galleryTitle": {
      "type": "string",
      "default": "Momentos GBB"
    },
    "galleryLinkLabel": {
      "type": "string",
      "default": "Ver galeria completa"
    },
    "ctaHeading1": {
      "type": "string"
    },
    "ctaHeading2": {
      "type": "string"
    },
    "ctaBody": {
      "type": "text"
    },
    "ctaButtons": {
      "type": "component",
      "component": "shared.cta-button",
      "repeatable": true
    }
  }
}
